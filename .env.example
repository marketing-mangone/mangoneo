# ─────────────────────────────────────────────
# BACKEND (Railway)
# ─────────────────────────────────────────────

# Genera uno con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-change-this-immediately

DEBUG=False

# Railway inyecta DATABASE_URL automáticamente al añadir PostgreSQL al proyecto.
# En dev local deja vacío para usar SQLite.
DATABASE_URL=

# Dominio de Railway — lo obtienes después de hacer deploy (ej: marketing-hub.up.railway.app)
ALLOWED_HOSTS=localhost,127.0.0.1

# Dominio de Vercel (sin trailing slash). Se añade a CORS automáticamente.
# Ej: https://marketing-hub.vercel.app
CORS_ALLOWED_ORIGINS=

# ─────────────────────────────────────────────
# CLOUDFLARE R2 (almacenamiento persistente)
# ─────────────────────────────────────────────
# Crea un bucket en R2 y genera un API token con permiso Object Read & Write.
# Account ID: Dashboard de Cloudflare → R2 → esquina superior derecha
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com

AWS_ACCESS_KEY_ID=r2-access-key-id
AWS_SECRET_ACCESS_KEY=r2-secret-access-key
AWS_STORAGE_BUCKET_NAME=marketing-hub-files
AWS_S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ─────────────────────────────────────────────
# FRONTEND (Vercel)
# ─────────────────────────────────────────────
# URL del backend en Railway (sin trailing slash)
NEXT_PUBLIC_API_URL=https://tu-backend.up.railway.app

# ─────────────────────────────────────────────
# META — Facebook + Instagram + Ads (Graph API)
# ─────────────────────────────────────────────
# Guía de setup completa: docs/META_SETUP.md
# 1. Crea una App tipo "Business" en developers.facebook.com
# 2. Agrega productos: Pages API, Instagram Graph API, Marketing API
# 3. Genera un System User Token (NO expira) en business.facebook.com con permisos:
#    pages_read_engagement, instagram_basic, instagram_manage_insights, ads_read
# 4. Corre: python manage.py authorize_meta  (verifica token)
#           python manage.py seed_meta_metrics
#           python manage.py sync_meta

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=                  # Facebook Page ID (numérico)
META_INSTAGRAM_ACCOUNT_ID=     # Instagram Business Account ID (numérico)
META_AD_ACCOUNT_ID=            # solo el número, sin 'act_'
